{
  "name": "vite-vue-ts-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest --project unit",
    "test:run": "vitest run --project unit",
    "test:coverage": "vitest run --coverage --project unit",
    "test:storybook": "vitest run --project storybook",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:staged": "prettier --check",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:staged": "eslint",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint 'src/**/*.{vue,css}'",
    "lint:css:fix": "stylelint 'src/**/*.{vue,css}' --fix",
    "lint:css:staged": "stylelint",
    "typecheck": "vue-tsc --noEmit",
    "hooks:install": "lefthook install",
    "hooks:uninstall": "lefthook uninstall",
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@chromatic-com/storybook": "^5.1.2",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/vue3-vite": "^10.3.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-vue": "^10.9.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "lefthook": "^2.1.6",
    "playwright": "^1.59.1",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "storybook": "^10.3.6",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
